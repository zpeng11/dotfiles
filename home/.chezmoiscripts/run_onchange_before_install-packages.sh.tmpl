#!/usr/bin/env bash
set -euo pipefail

homebrew_prefix="/opt/homebrew"

download_to_file() {
  local url="$1"
  local destination="$2"

  if command -v curl >/dev/null 2>&1; then
    curl -fsSL -o "$destination" "$url"
  elif command -v wget >/dev/null 2>&1; then
    wget -qO "$destination" "$url"
  else
    echo "Downloading $url requires curl or wget" >&2
    exit 1
  fi
}

run_downloaded_bash_script() {
  local url="$1"
  shift

  local tmpfile=""

  tmpfile="$(mktemp)"
  trap 'rm -f "${tmpfile:-}"' RETURN
  download_to_file "$url" "$tmpfile"
  /bin/bash "$tmpfile" "$@"
}

run_as_root() {
  if [[ $EUID -eq 0 ]]; then
    "$@"
  else
    sudo "$@"
  fi
}

setup_brew_env() {
  if [[ -x "${homebrew_prefix}/bin/brew" ]]; then
    eval "$("${homebrew_prefix}/bin/brew" shellenv)"
  fi
}

ensure_homebrew() {
  setup_brew_env
  if command -v brew >/dev/null 2>&1; then
    return 0
  fi

  if [[ $EUID -eq 0 ]]; then
    echo "Skipping Homebrew bootstrap: do not run macOS package installation as root" >&2
    exit 1
  fi

  if [[ ! -x /usr/bin/xcode-select ]]; then
    echo "Skipping Homebrew bootstrap: xcode-select not found" >&2
    exit 1
  fi

  if ! /usr/bin/xcode-select -p >/dev/null 2>&1; then
    echo "Xcode Command Line Tools are required; run 'xcode-select --install' first" >&2
    exit 1
  fi

  NONINTERACTIVE=1 run_downloaded_bash_script "https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh"
  setup_brew_env
}

install_ubuntu_packages() {
  if [[ ! -r /etc/os-release ]]; then
    echo "Skipping package installation: /etc/os-release not found"
    exit 0
  fi

  # shellcheck disable=SC1091
  source /etc/os-release
  if [[ "${ID:-}" != "ubuntu" ]]; then
    echo "Skipping package installation on unsupported distro: ${ID:-unknown}"
    exit 0
  fi

  local packages=(
{{- range .ubuntu.base }}
    {{ printf "%q" . }}
{{- end }}
{{- range .ubuntu.preview }}
    {{ printf "%q" . }}
{{- end }}
  )
  local missing_packages=()
  local package

  for package in "${packages[@]}"; do
    if ! dpkg -s "$package" >/dev/null 2>&1; then
      missing_packages+=("$package")
    fi
  done

  if ((${#missing_packages[@]} == 0)); then
    echo "Ubuntu packages already installed"
    exit 0
  fi

  run_as_root apt-get update -qq
  run_as_root env DEBIAN_FRONTEND=noninteractive apt-get install -y "${missing_packages[@]}"
}

install_macos_packages() {
  local packages=(
{{- range .macos.base }}
    {{ printf "%q" . }}
{{- end }}
{{- range .macos.preview }}
    {{ printf "%q" . }}
{{- end }}
  )
  local missing_packages=()
  local package

  ensure_homebrew
  setup_brew_env

  for package in "${packages[@]}"; do
    if ! brew list --formula "$package" >/dev/null 2>&1; then
      missing_packages+=("$package")
    fi
  done

  if ((${#missing_packages[@]} == 0)); then
    echo "macOS packages already installed"
    exit 0
  fi

  brew install "${missing_packages[@]}"
}

case "$(uname -s)" in
  Linux)
    install_ubuntu_packages
    ;;
  Darwin)
    install_macos_packages
    ;;
  *)
    echo "Skipping package installation on unsupported host: $(uname -s)"
    ;;
esac
